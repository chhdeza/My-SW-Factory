# Copy to .env and fill in. NEVER commit .env.

# --- Agent backends (at least one required) ---
CURSOR_API_KEY=
ANTHROPIC_API_KEY=

# --- GitHub (PRs, CI log review, merges) ---
# Fine-grained PAT or GitHub App token with contents/pull-requests/actions scopes.
GITHUB_TOKEN=

# --- Optional MCP server credentials (referenced from factory.yaml mcps:) ---
# SONAR_TOKEN=
# GITGUARDIAN_API_KEY=
# WIZ_CLIENT_ID=
# WIZ_CLIENT_SECRET=

# --- Deploy (only needed for real deploy hooks) ---
# GOOGLE_APPLICATION_CREDENTIALS=path/to/sa.json
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
